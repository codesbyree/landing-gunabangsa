---
import { AlertIcon } from "@hugeicons/core-free-icons"
import { HugeiconsIcon } from "@hugeicons/react"

import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert"
import SectionTitleAlt from "@/components/shared/section-title-alt.astro"
import RegistrationBenefits from "./registration-benefits.astro"
import AuthorInformation from "./author-information.astro"
---

<section class="flex w-full justify-center overflow-hidden bg-white px-4">
  <div class="flex w-full max-w-7xl flex-1 flex-col py-26">
    <SectionTitleAlt title="Registration Information" subtitle="INFORMATION" />

    <div
      class="relative grid grid-cols-1 gap-4 md:grid-cols-[.55fr_1fr] md:gap-10 lg:gap-20"
    >
      <div class="flex h-full w-full flex-col justify-end"></div>

      <div class="relative z-10 flex flex-col gap-4 text-slate-600">
        <Alert
          className="border-amber-200 bg-amber-50 text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-50"
        >
          <HugeiconsIcon
            icon={AlertIcon}
            size={16}
            className="shrink-0 text-red-400"
            color="currentColor"
          />
          <AlertTitle>Critical Information</AlertTitle>

          <AlertDescription>
            <ul
              class="list-outside list-disc space-y-2 leading-relaxed font-medium text-amber-900/80"
            >
              <li>
                Presenter (Online &amp; Onsite): The registration fee does not
                cover the publication of accepted papers.<ul
                  class="ml-4 list-outside list-[circle] space-y-1"
                >
                  <li>
                    Additional accepted papers: subject to an extra fee of USD
                    375 / IDR 5.750.000 each.
                  </li><li>
                    Student Presenter: Must provide a valid student ID.
                  </li>
                </ul>
              </li><li>
                Participant (Non-Presenter): Entitled to full access to sessions
                and conference certificate.<ul
                  class="ml-4 list-outside list-[circle] space-y-1"
                >
                  <li>
                    Onsite participants additionally receive seminar kit,
                    conference abstract e-book, coffee break and e-certificate
                    of participation.
                  </li><li>
                    Student Participant: Must provide a valid student ID.
                  </li>
                </ul>
              </li>
            </ul>
          </AlertDescription>
        </Alert>

        <p>
          We provide two modes of participation — Online and Onsite — to
          accommodate scholars from around the world. Registration is carried
          out through the IGERS system. Information about IGERS and the
          registration procedures can be found at the following <a
            href="https://drive.google.com/drive/folders/1HasEzy_fLQbXA384PPI97qH0VVXMRdck"
            target="_blank"
            class="text-red-600">link.</a
          >
        </p>

        <RegistrationBenefits />
        <AuthorInformation />
      </div>
    </div>
  </div>
</section>
